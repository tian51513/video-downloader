{
  "name": "video-downloader",
  "displayName": "Video Downloader",
  "version": "1.0.0",
  "description": "Chrome extension for detecting and downloading web videos",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build && node -e \"const fs=require('fs');['assets/offscreen.html','assets/offscreen.js','assets/save-helper.html','assets/save-helper.js'].forEach(f=>{try{fs.copyFileSync(f,'build/chrome-mv3-prod/'+f.split('/').pop())}catch(e){console.error('Copy failed:',f,e.message)}})\"",
    "clean": "rm -rf dist build .plasmo",
    "test": "vitest run --experimental.viteJsx",
    "test:watch": "vitest --experimental.viteJsx"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "antd": "^5.22.0",
    "dashjs": "^4.7.0",
    "dayjs": "^1.11.0",
    "hls.js": "^1.5.0",
    "mux.js": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.280",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "plasmo": "^0.90.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  },
  "manifest": {
    "name": "Video Downloader",
    "description": "Chrome extension for detecting and downloading web videos",
    "permissions": [
      "downloads",
      "storage",
      "sidePanel",
      "contextMenus",
      "activeTab",
      "tabs",
      "scripting",
      "alarms",
      "offscreen",
      "declarativeNetRequest"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "sharp"
    ]
  }
}
