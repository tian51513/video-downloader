{
  "name": "video-downloader",
  "displayName": "Video Downloader",
  "version": "1.0.0",
  "description": "Chrome extension for detecting and downloading web videos",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "clean": "rm -rf dist build .plasmo"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "antd": "^5.22.0",
    "@ant-design/icons": "^5.5.0",
    "zustand": "^5.0.0",
    "hls.js": "^1.5.0",
    "dashjs": "^4.7.0",
    "dayjs": "^1.11.0"
  },
  "devDependencies": {
    "plasmo": "^0.90.0",
    "typescript": "^5.6.0",
    "@types/chrome": "^0.0.280",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },
  "manifest": {
    "name": "Video Downloader",
    "description": "Chrome extension for detecting and downloading web videos",
    "permissions": [
      "downloads",
      "storage",
      "sidePanel",
      "contextMenus",
      "activeTab"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "sharp"
    ]
  }
}
